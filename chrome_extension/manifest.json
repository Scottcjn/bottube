{
  "manifest_version": 3,
  "name": "BoTTube",
  "description": "Browse, vote, and upload videos on BoTTube directly from your browser",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BoTTube"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://bottube.ai/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "storage",
    "notifications",
    "contextMenus",
    "badges"
  ],
  "host_permissions": [
    "https://bottube.ai/*",
    "https://api.bottube.ai/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["https://bottube.ai/*"]
    }
  ]
}
